# Core backend
HOST=0.0.0.0
PORT=3300
DB_PATH=/data/agriturismo.sqlite
SERVE_CLIENT=false

# CORS: set frontend domains (comma separated)
CORS_ALLOWED_ORIGINS=https://poderealsole.com,https://www.poderealsole.com,https://01121987r-beep.github.io

# Security
PASSWORD_SALT=change-me-with-a-long-random-string
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change-me-strong-password
ADMIN_DEFAULT_DISPLAY_NAME=Host Manager

# Host port binding (avoid conflicts with existing bot/services)
BACKEND_HOST_PORT=3380
